import bpy
import bmesh


def find_ngons(obj):
    """objのメッシュからNゴン(5角形以上のポリゴン)のface indexリストを返す"""
    if obj.type != 'MESH':
        return []

    bm = bmesh.new()
    bm.from_mesh(obj.data)
    bm.faces.ensure_lookup_table()

    ngon_indices = [f.index for f in bm.faces if len(f.verts) > 4]

    bm.free()
    return ngon_indices


def report_ngons(objects):
    """対象オブジェクト群のNゴン検出結果をコンソールに出力"""
    total = 0
    for obj in objects:
        if obj.type != 'MESH':
            continue
        indices = find_ngons(obj)
        if indices:
            print(f"[Nゴン検出] {obj.name}: {len(indices)}面 -> face index {indices}")
            total += len(indices)
        else:
            print(f"[OK] {obj.name}: Nゴンなし")
    print(f"--- 合計 {total} 面のNゴンを検出 ---")


def select_ngons_in_editmode(obj):
    """指定オブジェクトを編集モードにしてNゴンだけを選択状態にする"""
    bpy.context.view_layer.objects.active = obj
    bpy.ops.object.mode_set(mode='EDIT')

    bm = bmesh.from_edit_mesh(obj.data)
    bm.faces.ensure_lookup_table()

    for f in bm.faces:
        f.select = False
    for e in bm.edges:
        e.select = False
    for v in bm.verts:
        v.select = False

    for f in bm.faces:
        if len(f.verts) > 4:
            f.select = True

    bmesh.update_edit_mesh(obj.data)


# --- 実行部 ---
selected_meshes = [o for o in bpy.context.selected_objects if o.type == 'MESH']

if not selected_meshes:
    print("メッシュオブジェクトが選択されていません")
else:
    report_ngons(selected_meshes)

    # Nゴンを持つ最初のオブジェクトを編集モードにして視覚的に選択表示
    for obj in selected_meshes:
        if find_ngons(obj):
            select_ngons_in_editmode(obj)
            break